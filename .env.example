DEBUG=False
SECRET_KEY=replace-with-long-random-secret-key
ALLOWED_HOSTS=example.com,www.example.com

# Default database (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Optional PostgreSQL settings (if needed)
# POSTGRES_DB=ufu_db
# POSTGRES_USER=ufu_user
# POSTGRES_PASSWORD=replace-with-strong-db-password
# DATABASE_URL=postgres://ufu_user:replace-with-strong-db-password@db:5432/ufu_db

# Hide admin endpoint with non-standard path
ADMIN_URL=secure-admin-9f2kq7/

# API docs should be disabled in production by default
ENABLE_API_DOCS=False
SERVE_MEDIA_FILES=False
DRF_THROTTLE_ANON_RATE=120/minute
DRF_PAGE_SIZE=10

# CORS/CSRF strict lists
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Transport/cookie hardening
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Startup controls
RUN_MIGRATIONS=1
RUN_COLLECTSTATIC=1
